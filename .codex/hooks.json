{
  "description": "Sync Claude Code project skills and agents into local Codex bridge output.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/sync-claude-to-codex.mjs",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/sync-claude-to-codex.mjs",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
